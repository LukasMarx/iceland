{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Serve API",
			"type": "shell",
			"command": "node",
			"args": [
				"./node_modules/.bin/nx",
				"serve",
				"api"
			],
			"isBackground": true,
			"group": "serve"
		},
		{
			"label": "Serve API",
			"type": "shell",
			"command": "npx",
			"args": [
				"run",
				"api:serve"
			],
			"isBackground": true
		},
		{
			"label": "Serve API (npx)",
			"type": "shell",
			"command": "npx nx serve api",
			"args": [],
			"isBackground": true
		},
		{
			"label": "Build API",
			"type": "shell",
			"command": "npx",
			"args": [
				"run",
				"api:build:development"
			],
			"isBackground": false
		}
	]
}